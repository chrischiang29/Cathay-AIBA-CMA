# Google Vertex AI 設定
# 將你的 Service Account JSON Key 放到 credentials/ 目錄，並填入檔案名稱
GOOGLE_APPLICATION_CREDENTIALS=credentials/gen-lang-client.json

# Vertex AI 專案設定（從你的 GCP 專案取得）
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# LLM 模型選擇（建議 MVP 用 flash，正式上線可換 pro）
# gemini-1.5-flash  → 速度快、成本低（推薦 MVP）
# gemini-1.5-pro    → 品質更佳（推薦正式上線）
LLM_MODEL=gemini-1.5-flash
