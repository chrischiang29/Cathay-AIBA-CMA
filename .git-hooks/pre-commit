#!/bin/sh
# ============================================================
# Pre-commit Hook：機密檔案洩漏防護
# 安裝方式：複製此檔到 .git/hooks/pre-commit 並賦予執行權限
#   cp .git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
# ============================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔍 [pre-commit] 掃描機密檔案..."

BLOCKED=0

# ── 1. 禁止提交 .env 檔案（.env.example 允許）────────────────
if git diff --cached --name-only | grep -qE '(^|/)\.env$'; then
  echo "${RED}[BLOCKED] 偵測到 .env 即將被提交！${NC}"
  echo "  請執行：git reset HEAD <.env 路徑>"
  BLOCKED=1
fi

# ── 2. 禁止提交 credentials/*.json（*-example.json 允許）──────
CRED_FILES=$(git diff --cached --name-only | grep -E 'credentials/.*\.json$' | grep -viE 'example')
if [ -n "$CRED_FILES" ]; then
  echo "${RED}[BLOCKED] 偵測到 credentials/ 下的 JSON 即將被提交！${NC}"
  echo "$CRED_FILES"
  echo "  執行：git reset HEAD <檔案路徑>"
  BLOCKED=1
fi

# ── 3. 禁止提交已知高風險憑證檔名（example 檔除外）────────────
DANGEROUS_PATTERNS="gen-lang-client-api-key\.json|service.account\.json|.*-key\.json|.*_key\.json"
DANGEROUS_FILES=$(git diff --cached --name-only | grep -iE "$DANGEROUS_PATTERNS" | grep -viE 'example')
if [ -n "$DANGEROUS_FILES" ]; then
  echo "${RED}[BLOCKED] 偵測到疑似憑證 JSON 即將被提交！${NC}"
  echo "$DANGEROUS_FILES"
  echo "  執行：git reset HEAD <檔案路徑>"
  BLOCKED=1
fi

# ── 4. 掃描 JSON 內容是否含真實 private_key 值（非空字串）──────
STAGED_JSON=$(git diff --cached --name-only --diff-filter=ACM | grep '\.json$' | grep -viE 'example')
for FILE in $STAGED_JSON; do
  # private_key 值若為 "xxx" 或空字串則為範本，允許通過
  PK_VALUE=$(git show ":$FILE" 2>/dev/null | grep '"private_key"' | sed 's/.*"private_key"[[:space:]]*:[[:space:]]*"\(.*\)".*/\1/')
  if [ -n "$PK_VALUE" ] && [ "$PK_VALUE" != "xxx" ] && [ "$PK_VALUE" != "" ]; then
    echo "${RED}[BLOCKED] $FILE 含有真實 private_key，疑為 Service Account 金鑰！${NC}"
    echo "  執行：git reset HEAD $FILE"
    BLOCKED=1
  fi
done

# ── 結果 ─────────────────────────────────────────────────────
if [ "$BLOCKED" -eq 1 ]; then
  echo ""
  echo "${RED}✗ Commit 已被阻止。請移除上述機密檔案後再重新 commit。${NC}"
  echo "${YELLOW}  提示：若需強制跳過（不建議），使用 git commit --no-verify${NC}"
  exit 1
fi

echo "${GREEN}✓ 未偵測到機密檔案，Commit 允許通過。${NC}"
exit 0
